# Backend
DATABASE_URL=mysql://user:password@host:3306/dbname
JWT_SECRET=replace-with-long-random-secret
CORS_ORIGIN=https://mygamebookai.vercel.app
NODE_ENV=production

# Text LLM (OpenAI)
TEXT_LLM_API_KEY=
TEXT_LLM_API_URL=https://api.openai.com
TEXT_LLM_MODEL=gpt-4o-mini
# Safety cap for completion size (OpenAI-compatible chat/completions max is typically 16384)
TEXT_LLM_MAX_TOKENS=4096

# Image generation (Google Gemini)
IMAGE_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Payments (if enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Object storage (Cloudflare R2 - recommended)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mygamebookai-assets
# If empty, endpoint is derived from R2_ACCOUNT_ID
R2_ENDPOINT=
# Optional public base URL (custom domain or r2.dev). If omitted, signed URLs are returned.
R2_PUBLIC_BASE_URL=

# Optional legacy compatibility
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# BUILT_IN_FORGE_API_KEY=
# BUILT_IN_FORGE_API_URL=
